# OPENAI_API_KEY: Required for OpenAI API calls.
# Get yours here: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY="YOUR_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# APP_PASSCODE: The passcode required to access the application
# -----------------------------------------------------------------------------
APP_PASSCODE="your-secure-passcode"

# JWT_SECRET: A secret key used to sign the JWT tokens for authentication
# -----------------------------------------------------------------------------
JWT_SECRET="generate-a-secure-random-string-here"
