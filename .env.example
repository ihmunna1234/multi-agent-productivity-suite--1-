# GEMINI_API_KEY: Required for ALL AI features (Iqama OCR, Product Scout, Resume Studio, PDF OCR, Maps Extractor).
# The server will NOT start without this key.
# Get yours here: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY="YOUR_API_KEY"

# GOOGLE_MAPS_PLATFORM_KEY: Optional — enables Official Google Places API mode in the Maps Extractor.
# AI fallback (Gemini Search Grounding) works automatically without this key.
# Get yours here: https://developers.google.com/maps/documentation/places/web-service/overview
GOOGLE_MAPS_PLATFORM_KEY="YOUR_GOOGLE_MAPS_PLATFORM_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# APP_PASSCODE: The passcode used to restrict access to the dashboard.
APP_PASSCODE="YOUR_APP_PASSCODE"

# JWT_SECRET: The secret signing key used to sign and verify JWT tokens.
JWT_SECRET="YOUR_JWT_SECRET"

# SUPABASE: Required for the Employee Management System (projects, employees, timesheets, payroll).
# Create a free project at https://supabase.com, then go to Settings → API.
# Run the SQL migration script (supabase_migration.sql) in the SQL Editor to create the required tables.
SUPABASE_URL="YOUR_SUPABASE_URL"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
